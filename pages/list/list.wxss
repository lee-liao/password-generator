.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx;
  background: white;
}

.search-input {
  width: 100%;
  height: 72rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  font-size: 28rpx;
}

/* 记录列表 - 表格样式 */
.records-list {
  padding: 20rpx;
}

.record-row {
  display: flex;
  background: white;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.row-cell {
  flex: 1;
  padding: 32rpx 16rpx;
  text-align: center;
  font-size: 26rpx;
  border-right: 1rpx solid #f0f0f0;
  word-break: break-all;
  display: flex;
  align-items: center;
  justify-content: center;
}

.row-cell:last-child {
  border-right: none;
}

.cell-label {
  font-weight: 500;
  color: #333;
  flex: 1.2;
}

.cell-keyword {
  color: #667eea;
  flex: 1;
}

.cell-seed {
  color: #999;
  font-family: 'Courier New', monospace;
  flex: 0.8;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 60rpx;
}

.btn-add-first {
  width: 200rpx;
  height: 72rpx;
  background: #667eea;
  color: white;
  border-radius: 36rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-add-first::after {
  border: none;
}

/* 详情弹窗 */
.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.detail-content {
  width: 600rpx;
  background: white;
  border-radius: 24rpx;
  overflow: hidden;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.detail-close {
  font-size: 40rpx;
  color: #999;
  padding: 0 16rpx;
}

.detail-body {
  padding: 32rpx;
}

/* 密码显示 */
.detail-password {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.password-text {
  display: block;
  font-family: 'Courier New', monospace;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  word-break: break-all;
  margin-bottom: 16rpx;
}

.copy-btn {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: #667eea;
  color: white;
  border-radius: 20rpx;
  font-size: 24rpx;
}

/* 信息行 */
.detail-info {
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx dashed #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  color: #999;
  font-size: 26rpx;
}

.info-value {
  color: #333;
  font-size: 26rpx;
  font-weight: 500;
}

/* 描述 */
.detail-description {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.desc-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.desc-text {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.desc-links {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.url-link {
  color: #667eea;
  text-decoration: underline;
  font-size: 24rpx;
  word-break: break-all;
}

/* 操作按钮 */
.detail-actions {
  display: flex;
  gap: 16rpx;
}

.detail-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-btn::after {
  border: none;
}

.btn-copy-main {
  background: #667eea;
  color: white;
}

.btn-delete {
  background: #f5f5f5;
  color: #ff4d4f;
}
